# Supabase (local/dev & Vercel/prod)
# ----------------------------------------
# 接続先の確認: どちらのURLが使われているかログや P1001 のメッセージで確認できる。
#
# DATABASE_URL: 通常クエリ用。Supabase では Session Pooler (pgBouncer) 推奨。
#   - ローカル・Vercel ともに pooler を使うと P1001 を避けやすい（5432 が塞がれている環境でも 6543 で接続可能）
# DIRECT_URL: マイグレーション・introspect 用。Direct connection (db.*) を指定。
#   - prisma migrate / db push 時のみ使用。実行時クエリは DATABASE_URL を使う。
#
# sslmode=require は Supabase で必要になることが多い。
# <PROJECT> は Supabase のプロジェクト参照ID、<PW> は Database のパスワードに置き換える。

# Session Pooler (port 6543) — 通常のアプリ接続用（必須）
# dev/本番とも 6543 を使うと "connection closed" を避けやすい
DATABASE_URL="postgresql://postgres.<PROJECT>:<PW>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection (port 5432) — マイグレーション用のみ
DIRECT_URL="postgresql://postgres:<PW>@db.<PROJECT>.supabase.co:5432/postgres?sslmode=require"

# 注意:
# - "Error in PostgreSQL connection: Error { kind: Closed }" が出る場合:
#   1) DATABASE_URL を pooler (6543) にしているか確認
#   2) sslmode=require を付与
#   3) パスワードが Supabase の Database settings と一致するか確認
# - P1001 が出る場合、DATABASE_URL が db.*.supabase.co:5432 になっていないか確認する。
#   直で 5432 に接続しようとすると、FWや Supabase の制限で届かないことがある。
# - 正しくするには DATABASE_URL を pooler (6543) にし、DIRECT_URL だけ db.*:5432 にする。
# - Supabase ダッシュボード: Project Settings → Database で "Connection string" の
#   "Session mode" (Transaction でも可) を DATABASE_URL に、"Direct" を DIRECT_URL にコピー。

# Cron API 保護（POST /api/cron/run-scheduled, /api/cron/create-scheduled, GET /api/cron/auto-match-threads）
# Authorization: Bearer <value> または X-Cron-Secret ヘッダ、または query ?secret= で照合
CRON_SECRET=""

# football-data.org API（試合1時間前スレッド自動作成で使用）
# https://www.football-data.org/client/register で取得
FOOTBALL_DATA_API_KEY=""
FOOTBALL_DATA_BASE_URL="https://api.football-data.org/v4"

# 試合1時間前スレッドを自動作成する対象大会コード（カンマ区切り）
# 例: PL=プレミアリーグ, PD=ラリーガ, BL1=ブンデス, SA=セリエA, FL1=リーグアン, CL=チャンピオンズリーグ
FOOTBALL_TARGET_COMPETITIONS="PL,PD,BL1,SA,FL1,CL"
