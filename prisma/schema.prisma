generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Thread {
  id         Int       @id @default(autoincrement())
  teamId     Int
  title      String
  body       String    @default("")
  threadType String?   // "lineup" | "halftime" | "postmatch" = 試合中スレ（翻訳しない）
  createdAt  DateTime  @default(now())
  likes      Int       @default(0)
  deletedAt  DateTime?
  posts      Post[]

  @@map("スレッド")
}

model Post {
  id         Int       @id @default(autoincrement())
  threadId   Int
  author     String?
  body       String    @default("")
  createdAt  DateTime  @default(now())
  thread     Thread    @relation(fields: [threadId], references: [id])
  postLikes  PostLike[]

  @@index([threadId, createdAt])
  @@map("投稿")
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  anonId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, anonId])
  @@index([postId])
  @@map("post_likes")
}

model Report {
  id        Int      @id @default(autoincrement())
  kind      String
  targetId  Int
  reason    String?
  detail    String?
  pageUrl   String?
  ua        String?
  ip        String?
  createdAt DateTime @default(now())
}

model ScheduledPost {
  id        Int       @id @default(autoincrement())
  teamId    Int
  fixtureId Int       @default(0)  // 0 = 不明、それ以外は API の fixture id
  type      String    // "LINEUP" | "HALFTIME" | "POSTMATCH"
  title     String
  body      String    @default("")
  runAt     DateTime
  postedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([runAt])
  @@index([postedAt])
  @@unique([teamId, fixtureId, type])
  @@map("scheduled_posts")
}
